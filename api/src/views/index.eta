<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= it.title %></title>
  <!-- Load HTMX CDN -->
  <script src="/js/htmx.min.js"></script>
</head>
<body>
  <h1>Welcome to the Dashboard</h1>

  <!-- HTMX triggers an AJAX GET request on click and swaps the container innerHTML -->
  <div id="profile-container">
    <button hx-get="/example/user-profile" hx-target="#profile-container">
      Load Profile
    </button>
  </div>
</body>
</html>
